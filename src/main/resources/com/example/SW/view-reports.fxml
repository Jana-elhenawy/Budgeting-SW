<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<!--
  view-reports.fxml
  Controller: ReportsController
  Methods available: generateReport(), handleBackToDashboard()
  Fields: startDate, endDate, generateButton, expensePieChart,
          incomeExpenseBarChart, insightMessage
-->
<VBox spacing="0" alignment="TOP_CENTER"
      prefWidth="820" prefHeight="640"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.SW.Controller.ReportsController"
      stylesheets="@/com/example/SW/styles.css"
      style="-fx-background-color: #F3F6FB;">

    <!-- ── Top Bar ── -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: transparent transparent #D8DEE9 transparent;
                 -fx-padding: 18 32 18 32;">
        <Button text="← Back" onAction="#handleBackToDashboard"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #1A73E8;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-border-color: transparent;
                       -fx-padding: 4 10 4 0;" />
        <Label text="Financial Reports"
               style="-fx-font-size: 20px; -fx-font-weight: bold;
                      -fx-text-fill: #1A73E8; -fx-padding: 0 0 0 12;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="📈" style="-fx-font-size: 20px;" />
    </HBox>

    <!-- ── Content ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 28 32 28 32;">

            <!-- Date Range Card -->
            <VBox style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 12px;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12px;
                         -fx-border-width: 1px;
                         -fx-padding: 24;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);"
                  spacing="16">

                <Label text="Select Date Range"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                              -fx-text-fill: #1E293B;" />

                <Region style="-fx-background-color: #E2E8F0;
                               -fx-pref-height: 1px; -fx-max-height: 1px;" />

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="From"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;" />
                        <DatePicker fx:id="startDate" maxWidth="Infinity" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="To"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;" />
                        <DatePicker fx:id="endDate" maxWidth="Infinity" />
                    </VBox>
                    <VBox spacing="6" alignment="BOTTOM_LEFT">
                        <Label text=" " /> <!-- spacer to align button -->
                        <Button fx:id="generateButton"
                                text="📊  Generate Report"
                                onAction="#generateReport"
                                style="-fx-background-color: #4F46E5;
                                       -fx-text-fill: #FFFFFF;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 9px;
                                       -fx-padding: 10 22 10 22;
                                       -fx-cursor: hand;
                                       -fx-border-color: transparent;" />
                    </VBox>
                </HBox>

                <!-- Insight message -->
                <Label fx:id="insightMessage" text=""
                       wrapText="true"
                       style="-fx-font-size: 14px; -fx-text-fill: #4F46E5;
                              -fx-font-weight: bold;" />
            </VBox>

            <!-- Charts Row -->
            <HBox spacing="20">

                <!-- Pie Chart Card -->
                <VBox style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 12px;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 12px;
                             -fx-border-width: 1px;
                             -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);"
                      spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Expenses by Category"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1E293B;" />
                    <Region style="-fx-background-color: #E2E8F0;
                                   -fx-pref-height: 1px; -fx-max-height: 1px;" />
                    <PieChart fx:id="expensePieChart"
                              prefHeight="260"
                              labelsVisible="true"
                              animated="false"
                              VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Bar Chart Card -->
                <VBox style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 12px;
                             -fx-border-color: #E2E8F0;
                             -fx-border-radius: 12px;
                             -fx-border-width: 1px;
                             -fx-padding: 24;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);"
                      spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Income vs Expenses"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: #1E293B;" />
                    <Region style="-fx-background-color: #E2E8F0;
                                   -fx-pref-height: 1px; -fx-max-height: 1px;" />
                    <BarChart fx:id="incomeExpenseBarChart"
                              prefHeight="260"
                              animated="false"
                              VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis />
                        </xAxis>
                        <yAxis>
                            <NumberAxis />
                        </yAxis>
                    </BarChart>
                </VBox>

            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
