<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="620" prefWidth="600"
      spacing="0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.example.SW.Controller.BudgetController"
      stylesheets="@/com/example/SW/styles.css"
      style="-fx-background-color: #F3F6FB;">

    <!-- ── Top Bar ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: transparent transparent #D8DEE9 transparent;
                 -fx-padding: 18 28 18 28;">
        <Label text="Budgets"
               style="-fx-font-size: 20px; -fx-font-weight: bold;
                      -fx-text-fill: #1C2536;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleAddBudget" text="+ Add Budget"
                styleClass="btn-primary"
                style="-fx-padding: 9 18 9 18;" />
    </HBox>

    <!-- ── Table ───────────────────────────────────────────── -->
    <VBox style="-fx-padding: 24 28 0 28;" VBox.vgrow="ALWAYS">
        <TableView fx:id="budgetTable" prefHeight="430"
                   styleClass="table-view">
            <columns>
                <TableColumn fx:id="categoryCol" text="Category" prefWidth="180" />
                <TableColumn fx:id="limitCol"    text="Limit"    prefWidth="150" />
                <TableColumn fx:id="spentCol"    text="Spent"    prefWidth="150" />
            </columns>
        </TableView>
    </VBox>

    <!-- ── Bottom Bar ─────────────────────────────────────── -->
    <HBox alignment="CENTER_RIGHT"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #D8DEE9 transparent transparent transparent;
                 -fx-padding: 14 28 14 28;"
          VBox.vgrow="NEVER">
        <Button onAction="#handleBack" text="← Back to Dashboard"
                styleClass="btn-ghost"
                style="-fx-padding: 8 16 8 16;" />
    </HBox>

</VBox>
