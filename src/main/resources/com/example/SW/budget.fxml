<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="772.0" prefWidth="457.0" spacing="50.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.example.SW.Controller.BudgetController">

    <TableView fx:id="budgetTable">
        <columns>
            <TableColumn fx:id="categoryCol" text="Category" />
            <TableColumn fx:id="limitCol" text="Limit" />
            <TableColumn fx:id="spentCol" text="Spent" />
        </columns>
    </TableView>

    <Button onAction="#handleAddBudget" text="Add Budget" />
    <Button onAction="#handleBack" text="Back to Dashboard" />

</VBox>
