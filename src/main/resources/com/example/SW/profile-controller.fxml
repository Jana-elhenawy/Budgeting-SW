<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  profile-controller.fxml
  Controller: ProfileController
  Methods available: initialize(), handleSave(), handleBackToDashboard()
  Fields: nameField, emailField, currencyBox, languageBox, notificationCheck, statusLabel
-->
<VBox spacing="0" alignment="TOP_CENTER"
      prefWidth="820" prefHeight="640"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.SW.Controller.ProfileController"
      stylesheets="@/com/example/SW/styles.css"
      style="-fx-background-color: #F3F6FB;">

    <!-- ── Top Bar ── -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: transparent transparent #D8DEE9 transparent;
                 -fx-padding: 18 32 18 32;">
        <Button text="← Back" onAction="#handleBackToDashboard"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #1A73E8;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-border-color: transparent;
                       -fx-padding: 4 10 4 0;"/>
        <Label text="My Profile"
               style="-fx-font-size: 20px; -fx-font-weight: bold;
                      -fx-text-fill: #1A73E8; -fx-padding: 0 0 0 12;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="👤"
               style="-fx-font-size: 20px;" />
    </HBox>

    <!-- ── Content ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 28 32 28 32;">

            <!-- Profile Card -->
            <VBox style="-fx-background-color: #FFFFFF;
                         -fx-background-radius: 12px;
                         -fx-border-color: #E2E8F0;
                         -fx-border-radius: 12px;
                         -fx-border-width: 1px;
                         -fx-padding: 28;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 2);"
                  spacing="20">

                <!-- Section title -->
                <Label text="Personal Information"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;
                              -fx-text-fill: #1E293B;" />

                <Region style="-fx-background-color: #E2E8F0;
                               -fx-pref-height: 1px; -fx-max-height: 1px;" />

                <!-- Name -->
                <VBox spacing="6">
                    <Label text="Full Name"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;" />
                    <TextField fx:id="nameField"
                               promptText="Your full name"
                               style="-fx-background-color: #FFFFFF;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8px;
                                      -fx-background-radius: 8px;
                                      -fx-border-width: 1.5px;
                                      -fx-padding: 8 12 8 12;
                                      -fx-font-size: 14px;" />
                </VBox>

                <!-- Email -->
                <VBox spacing="6">
                    <Label text="Email Address"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-text-fill: #374151;" />
                    <TextField fx:id="emailField"
                               promptText="you@example.com"
                               style="-fx-background-color: #FFFFFF;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8px;
                                      -fx-background-radius: 8px;
                                      -fx-border-width: 1.5px;
                                      -fx-padding: 8 12 8 12;
                                      -fx-font-size: 14px;" />
                </VBox>

                <!-- Currency and Language row -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Currency"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;" />
                        <ComboBox fx:id="currencyBox" maxWidth="Infinity"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: #E2E8F0;
                                         -fx-border-radius: 8px;
                                         -fx-background-radius: 8px;
                                         -fx-border-width: 1.5px;" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Language"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;
                                      -fx-text-fill: #374151;" />
                        <ComboBox fx:id="languageBox" maxWidth="Infinity"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: #E2E8F0;
                                         -fx-border-radius: 8px;
                                         -fx-background-radius: 8px;
                                         -fx-border-width: 1.5px;" />
                    </VBox>
                </HBox>

                <!-- Notifications -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: #F8FAFC;
                             -fx-background-radius: 10px;
                             -fx-padding: 14;">
                    <CheckBox fx:id="notificationCheck" />
                    <VBox spacing="2">
                        <Label text="Enable Notifications"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;
                                      -fx-text-fill: #1E293B;" />
                        <Label text="Receive alerts for budget limits and goal progress"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748B;" />
                    </VBox>
                </HBox>

                <!-- Status label -->
                <Label fx:id="statusLabel" text=""
                       style="-fx-font-size: 13px;" wrapText="true" />

                <!-- Action buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Back to Dashboard" onAction="#handleBackToDashboard"
                            style="-fx-background-color: #FFFFFF;
                                   -fx-text-fill: #4F46E5;
                                   -fx-font-size: 14px;
                                   -fx-background-radius: 9px;
                                   -fx-border-color: #C7D2FE;
                                   -fx-border-radius: 9px;
                                   -fx-border-width: 1.5px;
                                   -fx-padding: 10 22 10 22;
                                   -fx-cursor: hand;" />
                    <Button text="💾  Save Profile" onAction="#handleSave"
                            style="-fx-background-color: #4F46E5;
                                   -fx-text-fill: #FFFFFF;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 9px;
                                   -fx-padding: 10 22 10 22;
                                   -fx-cursor: hand;
                                   -fx-border-color: transparent;" />
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
