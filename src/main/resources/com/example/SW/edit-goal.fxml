<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.SW.Controller.EditGoalController">

    <TextField fx:id="nameField" promptText="Goal Name"/>
    <TextField fx:id="targetField" promptText="Target Amount"/>
    <DatePicker fx:id="dateField"/>

    <Button text="Save Changes" onAction="#handleSave"/>

</VBox>
