<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    add-transaction-view.fxml  –  US#3: Add Transaction
    Linked controller: com.example.SW.Controller.AddTransactionController
-->
<AnchorPane prefHeight="540" prefWidth="440"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.SW.Controller.AddTransactionController"
            stylesheets="@/com/example/SW/styles.css"
            style="-fx-background-color: #F3F6FB;">

    <VBox layoutX="48" layoutY="36" spacing="0" prefWidth="344">

        <!-- Header -->
        <Label text="Add Transaction" styleClass="page-title"
               style="-fx-padding: 0 0 4 0;" />
        <Label text="Record a new income or expense"
               styleClass="page-subtitle"
               style="-fx-padding: 0 0 20 0;" />

        <!-- Type Toggle -->
        <Label text="TYPE" styleClass="field-label" />
        <HBox spacing="10" style="-fx-padding: 0 0 4 0;">
            <fx:define>
                <ToggleGroup fx:id="typeGroup" />
            </fx:define>
            <ToggleButton fx:id="expenseToggle" text="↓ Expense"
                          toggleGroup="$typeGroup" prefWidth="165"
                          styleClass="toggle-expense" />
            <ToggleButton fx:id="incomeToggle" text="↑ Income"
                          toggleGroup="$typeGroup" prefWidth="165"
                          styleClass="toggle-income" />
        </HBox>

        <!-- Amount -->
        <Label text="AMOUNT" styleClass="field-label" />
        <TextField fx:id="amountField" promptText="e.g. 150.00"
                   prefWidth="344" styleClass="text-field"
                   style="-fx-padding: 9 12 9 12;" />

        <!-- Description -->
        <Label text="DESCRIPTION" styleClass="field-label" />
        <TextField fx:id="descriptionField" promptText="e.g. Lunch at restaurant"
                   prefWidth="344" styleClass="text-field"
                   style="-fx-padding: 9 12 9 12;" />

        <!-- Category -->
        <Label text="CATEGORY" styleClass="field-label" />
        <ComboBox fx:id="categoryBox" prefWidth="344"
                  promptText="Select category"
                  style="-fx-padding: 4 12 4 12;" />

        <!-- Date -->
        <Label text="DATE" styleClass="field-label" />
        <DatePicker fx:id="datePicker" prefWidth="344"
                    style="-fx-padding: 4 12 4 12;" />

        <!-- Status Label -->
        <Label fx:id="statusLabel" text="" wrapText="true"
               prefWidth="344" styleClass="status-label" />

        <!-- Actions -->
        <HBox spacing="12" style="-fx-padding: 18 0 0 0;">
            <Button text="Save Transaction" onAction="#handleSaveTransaction"
                    prefWidth="216" styleClass="btn-primary"
                    style="-fx-padding: 11 0 11 0; -fx-font-size: 13px;" />
            <Button text="Cancel" onAction="#handleCancel"
                    prefWidth="116" styleClass="btn-ghost"
                    style="-fx-padding: 10 0 10 0;" />
        </HBox>

    </VBox>

</AnchorPane>
