<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.SW.Controller.GoalsController"
            prefHeight="400.0" prefWidth="600.0">


    <ListView fx:id="goalsList" centerShape="true" AnchorPane.topAnchor="50"
              AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10"
              AnchorPane.rightAnchor="10"/>
    <Button text="+ Add Goal" fx:id="addButton" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10" onAction="#openAddGoal"/>
    <Button text="Edit Goal" AnchorPane.rightAnchor="110" AnchorPane.topAnchor="10" onAction="#handleEditGoal"/>
    <Button text="Back to Dashboard" onAction="#handleBackToDashboard"/>




</AnchorPane>
