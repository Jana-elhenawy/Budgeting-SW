<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<!--
    signup-view.fxml  –  US#1: User Sign-Up
    Linked controller: com.example.SW.Controller.SignUpController
-->
<AnchorPane prefHeight="480" prefWidth="400"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.SW.Controller.SignUpController">

    <VBox layoutX="60" layoutY="40" spacing="12">

        <Label text="Create Account" style="-fx-font-size: 22; -fx-font-weight: bold;" />
        <Label text="Start your financial journey" style="-fx-text-fill: grey;" />

        <Label text="FULL NAME" />
        <TextField fx:id="fullNameField" promptText="John Doe" prefWidth="280" />

        <Label text="EMAIL" />
        <TextField fx:id="emailField" promptText="john@email.com" prefWidth="280" />

        <Label text="PASSWORD" />
        <PasswordField fx:id="passwordField" promptText="••••••••" prefWidth="280" />

        <Label text="CONFIRM PASSWORD" />
        <PasswordField fx:id="confirmPasswordField" promptText="••••••••" prefWidth="280" />

        <Button text="Create Account" onAction="#handleCreateAccount"
                prefWidth="280"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14;" />

        <Label fx:id="statusLabel" text="" wrapText="true" prefWidth="280" />

        <Hyperlink text="Already have an account? Log In" onAction="#handleGoToLogin" />

    </VBox>

</AnchorPane>
