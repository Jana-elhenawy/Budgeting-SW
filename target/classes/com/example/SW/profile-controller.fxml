<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500" prefWidth="600" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.SW.Controller.ProfileController">

   <VBox layoutX="50" layoutY="30" spacing="15">
      <Label text="Full Name" />
      <TextField fx:id="nameField" />

      <Label text="Email" />
      <TextField fx:id="emailField" />

      <Label text="Currency" />
      <ComboBox fx:id="currencyBox" />

      <Label text="Language" />
      <ComboBox fx:id="languageBox" />

      <CheckBox fx:id="notificationCheck" text="Enable Notifications" />

      <Button onAction="#handleSave" text="Save" />
      <Button text="Back to Dashboard" onAction="#handleBackToDashboard"/>
      <Label fx:id="statusLabel" />

   </VBox>

</AnchorPane>
